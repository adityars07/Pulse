// ============================================================
// GroundedDesk — Prisma Schema
// Multi-tenant data model with RLS support
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenant ──────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users            User[]
  knowledgeSources KnowledgeSource[]
  chunks           Chunk[]
  conversations    Conversation[]
  messages         Message[]
  apiKeys          ApiKey[]
  costLogs         CostLog[]
  stripeCustomer   StripeCustomer?
  auditLogs        AuditLog[]

  @@map("tenants")
}

// ── User ────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  AGENT
  VIEWER
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  email     String
  name      String?
  role      UserRole @default(VIEWER)
  avatar    String?
  password  String?  // Null for OAuth-only users
  provider  String?  // 'google', 'email', etc.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ── Knowledge Source ────────────────────────────────────────

enum SourceType {
  PDF
  DOCX
  MARKDOWN
  URL
}

enum SourceStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

model KnowledgeSource {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  type         SourceType
  name         String
  status       SourceStatus @default(PENDING)
  filePath     String?      @map("file_path")
  url          String?
  metadata     Json         @default("{}")
  chunkCount   Int          @default(0) @map("chunk_count")
  errorMessage String?      @map("error_message")
  version      Int          @default(1)
  previousVersionId String? @map("previous_version_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks Chunk[]

  previousVersion  KnowledgeSource?  @relation("SourceVersions", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions     KnowledgeSource[] @relation("SourceVersions")

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("knowledge_sources")
}

// ── Chunk ───────────────────────────────────────────────────

model Chunk {
  id         String   @id @default(uuid()) @db.Uuid
  sourceId   String   @map("source_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  content    String
  tokenCount Int      @map("token_count")
  metadata   Json     @default("{}")
  vectorId   String   @map("vector_id")
  createdAt  DateTime @default(now()) @map("created_at")

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sourceId])
  @@index([vectorId])
  @@map("chunks")
}

// ── Conversation ────────────────────────────────────────────

enum ConversationStatus {
  ACTIVE
  RESOLVED
  ESCALATED
}

model Conversation {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @map("tenant_id") @db.Uuid
  sessionId       String             @map("session_id")
  visitorInfo     Json               @default("{}") @map("visitor_info")
  status          ConversationStatus @default(ACTIVE)
  rating          Int?               // 1 = thumbs down, 5 = thumbs up
  assignedAgentId String?            @map("assigned_agent_id") @db.Uuid // Set when agent takes over
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages Message[]
  costLogs CostLog[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([sessionId])
  @@index([assignedAgentId])
  @@map("conversations")
}

// ── Message ─────────────────────────────────────────────────

enum MessageRole {
  USER
  ASSISTANT
  AGENT   // Human support agent (live takeover)
  SYSTEM
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  tenantId       String      @map("tenant_id") @db.Uuid
  role           MessageRole
  content        String
  citations      Json        @default("[]")
  attachments    Json        @default("[]") // [{ name: string, url: string, mimeType: string }]
  confidence     Float?
  tokenCost      Float?      @map("token_cost")
  latencyMs      Int?        @map("latency_ms")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([tenantId])
  @@map("messages")
}

// ── API Key ─────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String
  keyHash    String    @map("key_hash")
  keyPrefix  String    @map("key_prefix") // First 8 chars for display
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([keyHash])
  @@map("api_keys")
}

// ── Cost Log ────────────────────────────────────────────────

model CostLog {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  conversationId   String?  @map("conversation_id") @db.Uuid
  model            String
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  totalCost        Float    @map("total_cost")
  operation        String   @default("chat") // 'chat', 'embedding', 'eval'
  createdAt        DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([conversationId])
  @@map("cost_logs")
}

// ── Stripe Billing ───────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

model StripeCustomer {
  id                 String             @id @default(uuid()) @db.Uuid
  tenantId           String             @unique @map("tenant_id") @db.Uuid
  customerId         String             @unique @map("customer_id")     // Stripe cus_xxx
  subscriptionId     String?            @map("subscription_id")         // Stripe sub_xxx
  subscriptionItemId String?            @map("subscription_item_id")    // Stripe si_xxx (metered)
  priceId            String?            @map("price_id")
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodEnd   DateTime?          @map("current_period_end")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("stripe_customers")
}

// ── Audit Log ────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  userEmail String?  @map("user_email")
  action    String
  details   String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([createdAt])
  @@map("audit_logs")
}

